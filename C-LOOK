#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n){
    for(int i=0;i<n-1;i++)
        for(int j=0;j<n-i-1;j++)
            if(arr[j]>arr[j+1]){
                int t=arr[j]; arr[j]=arr[j+1]; arr[j+1]=t;
            }
}

int main() {
    int n, head, req[100], total = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i = 0; i < n; i++) scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    sort(req,n);

    int index;
    for(int i=0;i<n;i++) if(req[i]>head){ index=i; break; }

    printf("\nHead Movement Table:\n");
    printf("Current -> Next | Movement\n");

    for(int i=index;i<n;i++){
        int move=abs(head-req[i]);
        printf("%d -> %d | %d\n",head,req[i],move);
        total+=move;
        head=req[i];
    }

    printf("%d -> %d | %d\n",head,req[0],abs(head-req[0]));
    total+=abs(head-req[0]);
    head=req[0];

    for(int i=1;i<index;i++){
        int move=abs(head-req[i]);
        printf("%d -> %d | %d\n",head,req[i],move);
        total+=move;
        head=req[i];
    }

    printf("\nTotal Seek Length = %d\n", total);
    printf("Average Seek Length = %.2f\n", (float)total/n);

    return 0;
}
