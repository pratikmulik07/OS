#include <stdio.h>

int main() {
    int n, tq, time = 0, completed = 0;
    int at[100], bt[100], rt[100], ct[100], wt[100], tat[100];
    int queue[1000], front = 0, rear = 0;
    int visited[100] = {0};

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        printf("AT and BT for P%d: ", i+1);
        scanf("%d %d", &at[i], &bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    queue[rear++] = 0;
    visited[0] = 1;

    while(completed < n) {
        int i = queue[front++];

        if(rt[i] > tq) {
            time += tq;
            rt[i] -= tq;
        } else {
            time += rt[i];
            rt[i] = 0;
            ct[i] = time;
            completed++;
        }

        for(int j = 0; j < n; j++) {
            if(at[j] <= time && !visited[j]) {
                queue[rear++] = j;
                visited[j] = 1;
            }
        }

        if(rt[i] > 0) {
            queue[rear++] = i;
        }
    }

    float avg_tat = 0, avg_wt = 0;

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");

    for(int i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];

        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1, at[i], bt[i], ct[i], tat[i], wt[i]);

        avg_tat += tat[i];
        avg_wt += wt[i];
    }

    printf("\nAverage TAT = %.2f", avg_tat/n);
    printf("\nAverage WT = %.2f\n", avg_wt/n);

    return 0;
}
