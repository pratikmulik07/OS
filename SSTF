#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, head, req[100], visited[100]={0}, total = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i = 0; i < n; i++) scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("\nHead Movement Table:\n");
    printf("Current -> Next | Movement\n");

    for(int i = 0; i < n; i++) {
        int min = 9999, index = -1;

        for(int j = 0; j < n; j++) {
            if(!visited[j]) {
                int dist = abs(head - req[j]);
                if(dist < min) {
                    min = dist;
                    index = j;
                }
            }
        }

        printf("%d -> %d | %d\n", head, req[index], min);
        total += min;
        head = req[index];
        visited[index] = 1;
    }

    printf("\nTotal Seek Length = %d\n", total);
    printf("Average Seek Length = %.2f\n", (float)total/n);

    return 0;
}
