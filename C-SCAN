#include <stdio.h>
#include <stdlib.h>

void sort(int a[], int n) {
    for(int i=0;i<n-1;i++)
        for(int j=0;j<n-i-1;j++)
            if(a[j] > a[j+1]) {
                int t=a[j]; a[j]=a[j+1]; a[j+1]=t;
            }
}

int main() {
    int req[100], n, head, size, dir;
    int total = 0;

    printf("Enter number of requests: ");
    scanf("%d",&n);

    printf("Enter request queue: ");
    for(int i=0;i<n;i++) scanf("%d",&req[i]);

    printf("Enter head position: ");
    scanf("%d",&head);

    printf("Enter disk size: ");
    scanf("%d",&size);

    printf("Enter direction (1=Right, 0=Left): ");
    scanf("%d",&dir);

    sort(req, n);

    printf("\nHead Movement:\n");

    // 🔹 RIGHT DIRECTION
    if(dir == 1) {
        // move right
        for(int i=0;i<n;i++) {
            if(req[i] >= head) {
                printf("%d -> %d\n", head, req[i]);
                total += abs(head - req[i]);
                head = req[i];
            }
        }

        // go to end
        printf("%d -> %d\n", head, size-1);
        total += abs(head - (size-1));
        head = size-1;

        // jump to start
        printf("%d -> 0\n", head);
        total += abs(head - 0);
        head = 0;

        // continue right
        for(int i=0;i<n;i++) {
            if(req[i] > head) {
                printf("%d -> %d\n", head, req[i]);
                total += abs(head - req[i]);
                head = req[i];
            }
        }
    }

    // 🔹 LEFT DIRECTION
    else {
        // move left
        for(int i=n-1;i>=0;i--) {
            if(req[i] <= head) {
                printf("%d -> %d\n", head, req[i]);
                total += abs(head - req[i]);
                head = req[i];
            }
        }

        // go to start
        printf("%d -> 0\n", head);
        total += abs(head - 0);
        head = 0;

        // jump to end
        printf("%d -> %d\n", head, size-1);
        total += abs(head - (size-1));
        head = size-1;

        // continue left
        for(int i=n-1;i>=0;i--) {
            if(req[i] < head) {
                printf("%d -> %d\n", head, req[i]);
                total += abs(head - req[i]);
                head = req[i];
            }
        }
    }

    printf("\nTotal Seek Time = %d\n", total);
    printf("Average Seek Time = %.2f\n", (float)total/n);

    return 0;
}
