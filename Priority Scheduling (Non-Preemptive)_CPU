#include <stdio.h>

struct Process {
    int id, at, bt, pr, ct, tat, wt, completed;
};

int main() {
    int n, time = 0, completed = 0;
    float avg_tat = 0, avg_wt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[100];

    for(int i = 0; i < n; i++) {
        p[i].id = i+1;
        printf("Enter AT, BT, Priority for P%d: ", p[i].id);
        scanf("%d %d %d", &p[i].at, &p[i].bt, &p[i].pr);
        p[i].completed = 0;
    }

    while(completed < n) {
        int idx = -1, best_pr = 9999;

        for(int i = 0; i < n; i++) {
            if(p[i].at <= time && !p[i].completed) {
                if(p[i].pr < best_pr) {
                    best_pr = p[i].pr;
                    idx = i;
                }
            }
        }

        if(idx != -1) {
            p[idx].ct = time + p[idx].bt;
            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;

            time = p[idx].ct;
            p[idx].completed = 1;
            completed++;

            avg_tat += p[idx].tat;
            avg_wt += p[idx].wt;
        } else {
            time++;
        }
    }

    printf("\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].id, p[i].at, p[i].bt, p[i].pr,
        p[i].ct, p[i].tat, p[i].wt);
    }

    printf("\nAverage TAT = %.2f", avg_tat/n);
    printf("\nAverage WT = %.2f\n", avg_wt/n);

    return 0;
}
