#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n){
    for(int i=0;i<n-1;i++)
        for(int j=0;j<n-i-1;j++)
            if(arr[j]>arr[j+1]){
                int t=arr[j]; arr[j]=arr[j+1]; arr[j+1]=t;
            }
}

int main() {
    int n, head, size, dir, req[100], total = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i = 0; i < n; i++) scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &size);

    printf("Enter direction (0=Left,1=Right): ");
    scanf("%d", &dir);

    req[n++] = head;
    sort(req, n);

    int index;
    for(int i=0;i<n;i++) if(req[i]==head) index=i;

    printf("\nHead Movement Table:\n");
    printf("Current -> Next | Movement\n");

    if(dir==1){
        for(int i=index;i<n-1;i++){
            int move=abs(req[i]-req[i+1]);
            printf("%d -> %d | %d\n",req[i],req[i+1],move);
            total+=move;
        }
        total+=abs(req[n-1]-(size-1));
        printf("%d -> %d | %d\n",req[n-1],size-1,abs(req[n-1]-(size-1)));

        for(int i=index-1;i>=0;i--){
            int move=abs((i==index-1?size-1:req[i+1])-req[i]);
            printf("%d -> %d | %d\n",(i==index-1?size-1:req[i+1]),req[i],move);
            total+=move;
        }
    }

    printf("\nTotal Seek Length = %d\n", total);
    printf("Average Seek Length = %.2f\n", (float)total/(n-1));

    return 0;
}
